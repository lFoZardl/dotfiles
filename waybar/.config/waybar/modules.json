{
  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "performance": "<span color='#dddd66'>ïƒ§</span>",
      "balanced": "<span color='#66aadd'>ï‰ژ</span>",
      "power-saver": "<span color='#66dd66'>ïپ¬</span>"
    }
  },
  "custom/ddc_brightness": {
    "exec": "~/.config/waybar/luminosite.py",
    "return-type": "json",
    "format": "{icon}",
    "format-icons": [
      "َ°ƒڑ",
      "َ°ƒ›",
      "َ°ƒœ",
      "َ°ƒ‌",
      "َ°ƒ‍",
      "َ°ƒں",
      "َ°ƒ "
    ],
    "on-scroll-up": "~/.config/waybar/luminosite.py + 10",
    "on-scroll-down": "~/.config/waybar/luminosite.py - 10",
    "on-click": "~/.config/waybar/luminosite.py 0",
    "on-click-right": "",
    "tooltip": false
  },
  "custom/ddc_brightness_slider": {
    "return-type": "json",
    "format": "{percentage}%",
    "on-scroll-up": "echo '+' > /tmp/waybar-ddc-module-rx",
    "on-scroll-down": "echo '-' > /tmp/waybar-ddc-module-rx",
    "tooltip": false
  },
  "group/ddc_brightness": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 100,
      "children-class": "brightness",
      "transition-left-to-right": false
    },
    "modules": [
      "custom/ddc_brightness",
      "custom/ddc_brightness_slider"
    ]
  },
  "group/extras": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 100,
      "children-class": "extras",
      "transition-left-to-right": false
    },
    "modules": [
      "custom/menu",
      "tray"
    ]
  },
  "group/brightness": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 100,
      "children-class": "brightness",
      "transition-left-to-right": false
    },
    "modules": [
      "backlight",
      "backlight/slider"
    ]
  },
  "group/audio": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 100,
      "children-class": "audio",
      "transition-left-to-right": false
    },
    "modules": [
      "pulseaudio",
      "pulseaudio/slider"
    ]
  },
  "hyprland/workspaces": {
    "on-click": "activate",
    "format": "{id}",
    "format-icons": {
      "default": "َ°„°",
      "active": "َ°„¯"
    }
  },
  "cpu": {
    "format": "{icon}",
    "format-icons": [
      "â پ",
      "â ‰",
      "â ™",
      "â ›",
      "â ں",
      "â ؟"
    ],
    "interval": 1,
    "tooltip": true,
    "tooltip-format": "CPU Frequency: {avg_frequency} GHz",
    "on-click": "kitty btop"
  },
  "clock": {
    "format": "{:L%a%d\n%b%y\n%R}",
    "tooltip-format": "<span font='Courier New'><b>{:L%A %d %B %Y %T}</b>\n<span size='9pt'>{calendar}</span></span>",
    "calendar": {
      "mode": "year",
      "mode-mon-col": 3,
      "on-scroll": 1,
      "format": {
        "months": "<span color='#ffead3'><b>{}</b></span>",
        "days": "<span color='#ecc6d9'><b>{}</b></span>",
        "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
        "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
        "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
      }
    },
    "actions": {
      "on-click": "mode",
      "on-click-right": "shift_reset",
      "on-click-forward": "shift_up",
      "on-click-backward": "shift_down",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    }
  },
  "mpris": {
    "format": "َ°گژ",
    "interval": 1,
    "on-click": "playerctl play-pause",
    "on-click-right": "playerctl next",
    "on-click-middle": "playerctl previous",
    "tooltip": true,
    "tooltip-format": "{title}"
  },
  "custom/menu": {
    "format": "َ°…ƒ",
    "tooltip": false
  },
  "tray": {
    "spacing": 16,
    "reverse-direction": true,
    "icon-size": 12,
    "show-passive-items": false
  },
  "privacy": {
    "icon-size": 14,
    "transition-duration": 250,
    "modules": [
      {
        "type": "screenshare",
        "tooltip": false
      }
    ],
    "ignore": [
      {
        "type": "screenshare",
        "name": "obs"
      }
    ]
  },
  "network": {
    "format-icons": {
      "wifi": [
        "َ°¤¯",
        "َ°¤ں",
        "َ°¤¢",
        "َ°¤¥",
        "َ°¤¨"
      ],
      "ethernet": "َ°ˆ€",
      "disabled": "َ°¤­",
      "disconnected": "َ°¤©"
    },
    "format-wifi": "{icon}",
    "format-ethernet": "{icon}",
    "format-disconnected": "{icon}",
    "format-disabled": "{icon}",
    "interval": 5,
    "tooltip-format": "{essid}\t{gwaddr}",
    "on-click": "rfkill toggle wifi",
    "on-click-right": "nm-connection-editor",
    "tooltip": true,
    "max-length": 20
  },
  "bluetooth": {
    "interval": 5,
    "format-on": "َ°‚¯",
    "format-off": "َ°‚²",
    "format-disabled": "َ°‚²",
    "format-connected": "َ°‚±",
    "format-no-controller": "span size='14pt'>َ°‚¯",
    "tooltip": true,
    "tooltip-format": "{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_address}",
    "tooltip-format-enumerate-connected-battery": "{device_address} | Battery: {device_battery_percentage}%",
    "on-click": "rfkill toggle bluetooth",
    "on-click-right": "blueman-manager"
  },
  "pulseaudio#microphone": {
    "format": "{format_source}",
    "format-source": "َ°چ¬",
    "format-source-muted": "َ°چ­",
    "on-click": "pactl set-source-mute @DEFAULT_SOURCE@ toggle",
    "on-click-right": "pavucontrol -t 4",
    "tooltip": false
  },
  "pulseaudio/slider": {
    "min": 0,
    "max": 100,
    "orientation": "vertical"
  },
  "pulseaudio": {
    "interval": 1,
    "format": "{icon}",
    "format-icons": [
      "َ°•؟",
      "َ°–€",
      "َ°•¾"
    ],
    "format-muted": "َ°‌ں",
    "on-click-right": "pavucontrol -t 3",
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "reverse-scrolling": true,
    "tooltip": true,
    "tooltip-format": "Volume: {volume}%\n{desc}",
    "ignored-sinks": [
      "Easy Effects Sink"
    ]
  },
  "backlight/slider": {
    "min": 0,
    "max": 100,
    "orientation": "vertical",
    "device": "intel_backlight"
  },
  "backlight": {
    "device": "intel_backlight",
    "format": "{icon}",
    "format-icons": [
      "َ°ƒڑ",
      "َ°ƒ›",
      "َ°ƒœ",
      "َ°ƒ‌",
      "َ°ƒ‍",
      "َ°ƒں",
      "َ°ƒ "
    ],
    "reverse-scrolling": true,
    "smooth-scrolling-threshold": 0.2,
    "tooltip": false
  },
  "battery": {
    "interval": 5,
    "states": {
      "critical": 10
    },
    "format": "{icon}",
    "format-icons": [
      "َ°پ؛",
      "َ°پ»",
      "َ°پ¼",
      "َ°پ½",
      "َ°پ¾",
      "َ°پ؟",
      "َ°‚€",
      "َ°‚پ",
      "َ°‚‚",
      "َ°پ¹"
    ],
    "format-charging": "َ°‚„",
    "format-plugged": "َ°ڑ¥",
    "format-critical": "َ°‚ƒ",
    "tooltip": true,
    "tooltip-format": "Charge: {capacity}%",
    "tooltip-format-charging": "Charging: {capacity}%"
  },
  "custom/powermenu": {
    "format": "َ°گ¥",
    "on-click": "$HOME/.config/rofi/powermenu/powermenu.sh",
    "tooltip": false
  }
}
